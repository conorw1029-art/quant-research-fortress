[Unit]
Description=Fortress Strategy Executor (44 strategies, Telegram alerts)
After=network-online.target fortress-yfinance.service
Wants=network-online.target

[Service]
Type=simple
User=fortress
WorkingDirectory=/opt/fortress/04_codebase
EnvironmentFile=/opt/fortress/.env
ExecStart=/opt/fortress/venv/bin/python -X utf8 tick_live_executor.py --mock --poll 60
Restart=always
RestartSec=60
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
